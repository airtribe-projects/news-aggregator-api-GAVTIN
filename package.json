{
  "name": "news-aggregator-api",
  "version": "1.0.0",
  "description": "Personalized News Aggregator REST API with Node.js, Express, bcrypt, and JWT",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --testEnvironment node --forceExit --detectOpenHandles --runInBand"
  },
  "keywords": ["news", "aggregator", "api", "nodejs", "express", "jwt"],
  "author": "Gaurav Sinha",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.6.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^6.3.4"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.js"],
    "resetModules": true,
    "coverageDirectory": "coverage",
    "collectCoverageFrom": ["src/**/*.js"]
  }
}
